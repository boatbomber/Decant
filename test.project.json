{
  "name": "DecantTest",
  "tree": {
    "$className": "DataModel",

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "SignalBehavior": "Deferred"
      }
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",

      "DevPackages": {
        "$path": "DevPackages"
      },

      "Packages": {
        "$className": "Folder",

        "Decant": {
          "$path": "src"
        }
      },

      "TestProject": {
        "$path": "tests"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",

      "run-tests": {
        "$path": "scripts/run-tests.server.luau"
      }
    }
  }
}
